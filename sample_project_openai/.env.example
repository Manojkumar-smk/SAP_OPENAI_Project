# ──────────────────────────────────────────────────────────
# SAP AI Templates — Sample Project Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# ── SAP HANA Cloud (BTP Trial) ─────────────────────────────
HANA_HOST=your-hana-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=your-password-here
HANA_CERTIFICATE=        # optional — leave blank for BTP Trial

# ── OpenAI API (replaces SAP Gen AI Hub) ───────────────────
# Get from: platform.openai.com → API Keys → Create new secret key
OPENAI_API_KEY=sk-...

# ── Vector Store ───────────────────────────────────────────
# Table created by setup_sample_data.py — keep as VECTOR_STORE
VECTOR_TABLE_NAME=VECTOR_STORE
