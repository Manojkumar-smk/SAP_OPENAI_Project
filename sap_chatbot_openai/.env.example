# Copy this file to .env and fill in your values

# ── HANA Credentials (SAP BTP Trial) ─────────────────────
HANA_HOST=your-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=YourPassword
HANA_CERTIFICATE=        # optional

# ── OpenAI API Key ────────────────────────────────────────
# Get from: platform.openai.com → API Keys → Create new secret key
OPENAI_API_KEY=sk-...

# ── Vector Store (needed only if enable_rag=True) ─────────
# Must match the table created by hana_vector_store_openai/
VECTOR_TABLE_NAME=VECTOR_STORE

# ── SQL Tables (needed only if enable_sql=True) ───────────
# Comma-separated list of HANA tables the chatbot can query
# SQL_TABLES=SALES_ORDERS,PRODUCTS
