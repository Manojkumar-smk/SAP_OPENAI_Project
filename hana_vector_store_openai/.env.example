# Copy this file to .env and fill in your values

# ── HANA Credentials (SAP BTP Trial) ─────────────────────
HANA_HOST=your-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=YourPassword
HANA_CERTIFICATE=        # optional

# ── OpenAI API Key ────────────────────────────────────────
# Get from: platform.openai.com → API Keys → Create new secret key
OPENAI_API_KEY=sk-...

# ── Vector Table Settings ─────────────────────────────────
VECTOR_TABLE_NAME=VECTOR_STORE
VECTOR_DIMENSION=1536    # text-embedding-3-small / ada-002 → 1536
                         # text-embedding-3-large           → 3072
